{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "allowJs": false,
    "rootDir": "assets/js",
    "outDir": "assets/js/build",
    "lib": ["DOM", "ES2020"],
    "resolveJsonModule": true
  },
  "include": ["assets/js/**/*.ts"]
}
